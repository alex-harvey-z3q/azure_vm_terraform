from flask import Flask, jsonify, request

app = Flask(__name__)


@app.get("/health")
def health():
    return jsonify({"status": "ok"}), 200


@app.post("/build")
def build():
    payload = request.get_json(silent=True) or {}
    required = [
        "topology_type",
        "requested_by",
        "requested_by_email",
        "booking_id",
        "booking_start",
        "booking_end",
        "booking_duration_hours",
    ]
    missing = [field for field in required if not payload.get(field)]
    if missing:
        return jsonify({"status": "error", "missing_fields": missing}), 400

    return jsonify(
        {
            "status": "accepted",
            "message": "Placeholder build endpoint reached",
            "received": payload,
        }
    ), 200


if __name__ == "__main__":
    app.run(host="{{ api_listen_host }}", port={{ api_listen_port }})
